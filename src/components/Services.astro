---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const services = t.services;

const serviceIcons: Record<string, string> = {
  code: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
    <polyline points="16 18 22 12 16 6"/>
    <polyline points="8 6 2 12 8 18"/>
  </svg>`,
  automation: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
  </svg>`,
  consulting: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
  </svg>`,
};

const serviceColors = ['--color-primary', '--color-secondary', '--color-accent'];
---

<section
  id="services"
  class="py-28 relative"
  aria-labelledby="services-heading"
>
  <div class="section-container">
    <!-- Section header -->
    <div class="mb-14" data-reveal>
      <span class="inline-block text-xs font-semibold tracking-widest uppercase text-primary mb-3">
        {services.section_label}
      </span>
      <h2
        id="services-heading"
        class="text-3xl sm:text-4xl md:text-5xl font-bold text-text leading-tight"
      >
        {services.section_title}
        <span class="gradient-text"> {services.section_title_accent}</span>
      </h2>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {services.items.map((service, i) => (
        <article
          data-reveal
          data-reveal-delay={`${i + 1}`}
          class="group relative p-7 rounded-xl border border-border bg-surface card-hover overflow-hidden"
          aria-label={service.name}
        >
          <!-- Background glow on hover -->
          <div
            class="absolute -inset-px rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
            style={`background: radial-gradient(circle at top left, color-mix(in srgb, var(${serviceColors[i]}) 6%, transparent), transparent 60%);`}
            aria-hidden="true"
          ></div>

          <!-- Number -->
          <div
            class="absolute top-5 right-6 text-5xl font-black opacity-5 group-hover:opacity-10 transition-opacity select-none pointer-events-none"
            aria-hidden="true"
          >
            0{i + 1}
          </div>

          <!-- Icon -->
          <div
            class="w-11 h-11 rounded-xl flex items-center justify-center mb-5 transition-all duration-300"
            style={`background: color-mix(in srgb, var(${serviceColors[i]}) 12%, transparent); color: var(${serviceColors[i]}); border: 1px solid color-mix(in srgb, var(${serviceColors[i]}) 25%, transparent);`}
          >
            <Fragment set:html={serviceIcons[service.icon]} />
          </div>

          <!-- Content -->
          <h3 class="text-lg font-semibold text-text mb-2 group-hover:text-white transition-colors">
            {service.name}
          </h3>
          <p class="text-sm text-muted leading-relaxed mb-6">
            {service.description}
          </p>

          <!-- Subtle CTA -->
          <a
            href="#contact"
            class="inline-flex items-center gap-1.5 text-xs font-semibold transition-colors duration-200"
            style={`color: var(${serviceColors[i]});`}
          >
            {lang === 'en' ? "Let's talk" : 'Conversemos'}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>
      ))}
    </div>

    <!-- Process CTA strip -->
    <div
      data-reveal
      data-reveal-delay="4"
      class="mt-10 p-6 md:p-8 rounded-xl border border-border bg-surface flex flex-col sm:flex-row items-center justify-between gap-6"
    >
      <div>
        <p class="text-sm font-semibold text-text mb-1">
          {lang === 'en' ? 'Ready to start your project?' : '¿Listo para iniciar tu proyecto?'}
        </p>
        <p class="text-sm text-muted">
          {lang === 'en'
            ? 'Get a free consultation and a tailored solution proposal.'
            : 'Recibe una consulta gratuita y una propuesta de solución a medida.'}
        </p>
      </div>
      <a
        href="#contact"
        class="shrink-0 inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary text-white font-semibold text-sm hover:bg-primary-hover transition-colors whitespace-nowrap"
        data-magnetic
      >
        {lang === 'en' ? 'Get Started' : 'Comenzar'}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
