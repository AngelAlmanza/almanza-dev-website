---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const blog = t.blog;

// Placeholder cards for coming-soon state
const placeholders = [
  {
    category: lang === 'en' ? 'Architecture' : 'Arquitectura',
    readTime: lang === 'en' ? '8 min read' : '8 min de lectura',
  },
  {
    category: lang === 'en' ? 'Automation' : 'Automatización',
    readTime: lang === 'en' ? '6 min read' : '6 min de lectura',
  },
  {
    category: lang === 'en' ? 'SaaS' : 'SaaS',
    readTime: lang === 'en' ? '10 min read' : '10 min de lectura',
  },
];
---

<section
  id="blog"
  class="py-28 relative"
  style="background: linear-gradient(180deg, var(--color-bg) 0%, color-mix(in srgb, var(--color-surface) 40%, var(--color-bg)) 100%);"
  aria-labelledby="blog-heading"
>
  <div class="section-container">
    <!-- Section header -->
    <div class="mb-14 flex flex-col sm:flex-row sm:items-end justify-between gap-6" data-reveal>
      <div>
        <span class="inline-block text-xs font-semibold tracking-widest uppercase text-primary mb-3">
          {blog.section_label}
        </span>
        <h2
          id="blog-heading"
          class="text-3xl sm:text-4xl md:text-5xl font-bold text-text leading-tight"
        >
          {blog.section_title}
          <span class="gradient-text">{blog.section_title_accent}</span>
        </h2>
      </div>

      <!-- YouTube CTA -->
      <a
        href="#"
        class="shrink-0 inline-flex items-center gap-2 px-4 py-2.5 rounded-lg border border-border text-sm font-medium text-muted hover:text-text hover:border-[color-mix(in_srgb,#FF0000_50%,var(--color-border))] transition-all duration-200"
        aria-label={blog.follow_cta}
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#FF0000" aria-hidden="true">
          <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
          <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white"/>
        </svg>
        {blog.follow_cta}
      </a>
    </div>

    <!-- Coming soon cards (skeleton-style) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
      {placeholders.map((ph, i) => (
        <div
          data-reveal
          data-reveal-delay={`${i + 1}`}
          class="relative rounded-xl border border-border bg-surface p-6 overflow-hidden"
        >
          <!-- Blur overlay — coming soon -->
          <div class="absolute inset-0 backdrop-blur-sm bg-surface opacity-50 z-10 rounded-xl" aria-hidden="true"></div>
          <div class="absolute inset-0 flex items-center justify-center z-20">
            <span class="px-3 py-1.5 text-xs font-semibold rounded-full bg-bg border border-border text-muted">
              {blog.coming_soon}
            </span>
          </div>

          <!-- Skeleton content -->
          <div class="space-y-3" aria-hidden="true">
            <div class="flex items-center justify-between">
              <span class="text-xs font-medium text-primary bg-surface-2 px-2.5 py-1 rounded-md border border-border-subtle">
                {ph.category}
              </span>
              <span class="text-xs text-muted">{ph.readTime}</span>
            </div>
            <div class="h-5 bg-surface-2 rounded w-3/4"></div>
            <div class="h-4 bg-surface-2 rounded w-full"></div>
            <div class="h-4 bg-surface-2 rounded w-5/6"></div>
            <div class="h-4 bg-surface-2 rounded w-2/3"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Coming soon message -->
    <div
      data-reveal
      data-reveal-delay="4"
      class="text-center p-8 rounded-xl border border-border-subtle bg-surface"
    >
      <div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-4 text-primary"
        style="background: color-mix(in srgb, var(--color-primary) 10%, transparent); border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
          <path d="M12 6v6l4 2"/>
        </svg>
      </div>
      <p class="text-sm font-medium text-text mb-1">{blog.coming_soon}</p>
      <p class="text-sm text-muted max-w-sm mx-auto">{blog.coming_soon_text}</p>
    </div>
  </div>
</section>
